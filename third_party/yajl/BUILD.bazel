package(default_visibility = ["//visibility:public"])

cc_library(
    name = "yajl",
    srcs = ["yajl_tree.cpp"],
    hdrs = ["yajl_tree.h"],
    include_prefix = "yajl",
)

cc_library(
    name = "real_yajl",
    srcs = glob([
        "real/src/*.c",
        "real/src/*.h",
    ]),
    hdrs = glob(["real/src/api/*.h"]),
    includes = ["real/src"],
    strip_include_prefix = "real/src/api",
    include_prefix = "yajl",
)
